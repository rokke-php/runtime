# Auto convert line endings
* text=auto

# Source code
*.php text diff=php eol=lf

# Documentation
*.md text eol=lf
LICENSE text eol=lf
CHANGELOG.md text eol=lf
CONTRIBUTING.md text eol=lf
CODE_OF_CONDUCT.md text eol=lf
SECURITY.md text eol=lf
ARCHITECTURE.md text eol=lf
TESTING.md text eol=lf

# Configuration
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.neon text eol=lf
.editorconfig text eol=lf

# Export ignore - not needed in distributions
/tests export-ignore
/docs export-ignore
/.github export-ignore
/.gitignore export-ignore
/.gitattributes export-ignore
/phpunit.xml.dist export-ignore
/phpstan.neon.dist export-ignore
/.php-cs-fixer.dist.php export-ignore
/CONTRIBUTING.md export-ignore
/TESTING.md export-ignore
/ARCHITECTURE.md export-ignore
/CODE_OF_CONDUCT.md export-ignore
/SECURITY.md export-ignore
/CHANGELOG.md export-ignore
/MANIFESTO.md export-ignore
/PACKAGE.md export-ignore
