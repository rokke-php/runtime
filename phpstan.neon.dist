parameters:
    level: max
    paths:
        - src
        - tests
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: true
    checkUninitializedProperties: true
    checkImplicitMixed: true
    parallel:
        maximumNumberOfProcesses: 4
    reportUnmatchedIgnoredErrors: true

    # Swoole classes are only available at runtime (production server).
    # Analysis runs without ext-swoole installed, so we stub the symbols here.
    stubFiles:
        - stubs/Swoole.stub.php

    scanFiles:
        - stubs/PHPUnit.stub.php

    bootstrapFiles:
        - vendor/autoload.php

    ignoreErrors:
        # Coroutine::create() returns int|false; the int-cast is guarded by the RuntimeException above it
        - message: '#Cannot cast mixed to int#'
          path: src/CoroutineManager.php

        # WaitGroup is resolved from ext-swoole in CI but from the stub locally.
        # reportUnmatched: false because CI always finds the class (no error to suppress there).
        -
            message: '#(Instantiated class|Call to method (add|done|wait)\(\) on an unknown class) Swoole\\Coroutine\\WaitGroup#'
            path: src/CoroutineManager.php
            reportUnmatched: false

        # PHPUnit stubs are minimal — only TestCase class + basic asserts are modelled.
        # In CI, real PHPUnit types are resolved via autoloader; local analysis accepts this gap.
        - message: '#Call to an undefined method .*::(createStub|createMock|once|exactly|never|any|logicalOr|logicalAnd|equalTo|assertSame|assertNotSame|assertInstanceOf|assertTrue|assertFalse|assertNull|assertNotNull|assertCount|assertContains|assertContainsOnlyInstancesOf|assertStringContainsString|assertIsBool|assertGreaterThan|assertGreaterThanOrEqual|assertIsInt|assertIsString|assertIsArray|assertFileExists|assertFileDoesNotExist|expectException|expectExceptionMessage|markTestSkipped)\(\)#'
          path: tests/*
        - message: '#Cannot call method (expects|method|with|willThrowException|willReturn|willReturnCallback)\(\) on mixed#'
          path: tests/*
        - message: '#Parameter .* expects .*, mixed given#'
          path: tests/*
        - message: '#Method .* should return .* but returns mixed#'
          path: tests/*
        - message: '#Class .* has an uninitialized property .*#'
          path: tests/*

        # Swoole\Coroutine\run() and WaitGroup are only available with ext-swoole in CI.
        - message: '#Function Swoole\\Coroutine\\run not found#'
          path: tests/*
        - message: '#Cannot call method getMessage\(\) on .*\|null#'
          path: tests/*

        # Variables assigned inside Swoole\Coroutine\run() closures look nullable to PHPStan;
        # assertions inside the closure guarantee they are set by the time we access them.
        - message: '#Cannot access property \$\w+ on .*\|null#'
          path: tests/*

        # Method is declared unused by PHPStan but kept as a test helper for future tests.
        - message: '#Method .* is unused#'
          path: tests/*

        # Anonymous-class properties that are written via reference bindings look
        # "never read" to PHPStan because the read happens through the outer variable.
        - message: '#Property .* is never read, only written#'
          path: tests/*

        # Outer variables captured by-reference in closures lose their array type
        # context when PHPStan analyses the closure body; the runtime type is correct.
        - message: '#Cannot access an offset on mixed#'
          path: tests/*

        # Intentional "no type" fixture handlers in tests exercise compiler error paths.
        - message: '#Method .* has no return type specified#'
          path: tests/*
        - message: '#Method .* has parameter \$\w+ with no type specified#'
          path: tests/*
        - message: '#has no value type specified in iterable type array#'
          path: tests/*

        # HandlerCompiler compiles class-strings whose __invoke makes them callable;
        # PHPStan cannot prove object is callable without narrow type information.
        - message: '#Trying to invoke object but it might not be a callable#'
          path: src/Build/HandlerCompiler.php
